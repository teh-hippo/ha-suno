#!/usr/bin/env bash
# Pre-commit hook: fast checks on staged files only.
set -e

# Collect staged Python files
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "🔍 Pre-commit: ruff check (staged files)..."
echo "$STAGED" | xargs uv run ruff check --no-fix

echo "🔍 Pre-commit: ruff format (staged files)..."
echo "$STAGED" | xargs uv run ruff format --check

# Run matching tests for changed source modules
TEST_ARGS=""
for f in $STAGED; do
    mod=$(basename "$f" .py)
    case "$f" in
        custom_components/suno/*.py)
            test_file="tests/test_${mod}.py"
            [ -f "$test_file" ] && TEST_ARGS="$TEST_ARGS $test_file"
            ;;
        tests/*.py)
            TEST_ARGS="$TEST_ARGS $f"
            ;;
    esac
done

if [ -n "$TEST_ARGS" ]; then
    echo "🔍 Pre-commit: pytest (changed modules)..."
    # shellcheck disable=SC2086
    uv run pytest $TEST_ARGS -x -q --timeout=30 2>&1 | tail -3
fi

echo "✅ Pre-commit checks passed"
